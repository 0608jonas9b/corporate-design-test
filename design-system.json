      { "token": "subhead",   "pt": 18,   "px": 24, "weight": 700, "use": "Lead/Intro-Satz, Untertitel" },
      { "token": "lead",      "pt": 16,   "px": 21, "weight": 700, "use": "Einleitungssatz fett über Fließtext" },
      { "token": "body",      "pt": 14,   "px": 19, "weight": 400, "use": "Standard-Fließtext" },
      { "token": "bodySmall", "pt": 13.5, "px": 18, "weight": 400, "use": "Häufigster Fließtext / mehrspaltig" },
      { "token": "caption",   "pt": 12,   "px": 16, "weight": 400, "use": "Fußzeile, Bildunterschrift" },
      { "token": "small",     "pt": 10,   "px": 13, "weight": 400, "use": "Kleine Labels" },
      { "token": "micro",     "pt": 9,    "px": 12, "weight": 400, "use": "Seitenzahl, Mikro-Labels" }
    ],
    "lineHeight": { "tight": 1.1, "normal": 1.3, "relaxed": 1.45 }
